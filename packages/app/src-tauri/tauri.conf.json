{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "The Next",
  "version": "0.1.0",
  "identifier": "com.yiyi.app",
  "build": {
    "beforeDevCommand": "cd ../core && bun --hot src/server/main.ts & vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd ../.. && bun run build:core && cd packages/app && tsc && vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "The Next",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/the-next-core"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
